# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL connection string (asyncpg driver required)
# DigitalOcean Managed DB:  postgresql+asyncpg://user:pass@host:25060/netmonitor?ssl=require
# Render.com Postgres:       postgresql+asyncpg://user:pass@host:5432/netmonitor
# Local dev:                 postgresql+asyncpg://postgres:postgres@localhost:5432/netmonitor
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/netmonitor

# Supabase — used for API key validation against the profiles table
SUPABASE_URL=https://tiviipaamwvfjvoscnyk.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Runtime environment (development | production)
ENVIRONMENT=development

# Port to bind uvicorn (used by some PaaS providers)
PORT=8000
