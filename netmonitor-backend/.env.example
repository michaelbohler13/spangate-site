# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# On Vercel, set these in Project → Settings → Environment Variables.

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (asyncpg driver).
#
# Find this in Supabase → Project Settings → Database → Connection string
# → choose "URI" → select "Transaction pooler" for serverless / Vercel.
# Replace [YOUR-PASSWORD] with your Supabase database password.
#
# Transaction pooler (recommended for serverless):
DATABASE_URL=postgresql+asyncpg://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Direct connection (for local dev or migrations):
# DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── API Key validation ────────────────────────────────────────────────────────
# Supabase project credentials — used by auth.py to look up hashed API keys.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Vercel Cron secret ────────────────────────────────────────────────────────
# Vercel automatically injects this as `Authorization: Bearer <secret>` on
# cron invocations.  Set the same value in Vercel → Project → Settings →
# Environment Variables → CRON_SECRET.
CRON_SECRET=your_cron_secret_here

# ── Local dev only ────────────────────────────────────────────────────────────
# Port to bind uvicorn when running locally.
PORT=8000
