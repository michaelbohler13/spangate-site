{
  "rewrites": [
    { "source": "/configwizard", "destination": "/configwizard/index.html" },
    { "source": "/configwizard/wizard", "destination": "/configwizard/wizard.html" },
    { "source": "/configwizard/topology", "destination": "/configwizard/topology.html" },
    { "source": "/configwizard/netdoctor", "destination": "/configwizard/netdoctor.html" },
    { "source": "/configwizard/instant-on-wizard", "destination": "/configwizard/instant-on-wizard.html" },
    { "source": "/configwizard/dashboard", "destination": "/configwizard/dashboard.html" },
    { "source": "/configwizard/login", "destination": "/configwizard/login.html" },
    { "source": "/configwizard/profile", "destination": "/configwizard/profile.html" },
    { "source": "/netmonitor", "destination": "/netmonitor/index.html" },
    { "source": "/netmonitor/dashboard", "destination": "/netmonitor/dashboard.html" },
    { "source": "/netmonitor/install-pi", "destination": "/netmonitor/install-pi.html" },
    { "source": "/netmonitor/install-windows", "destination": "/netmonitor/install-windows.html" },
    { "source": "/netmonitor/settings", "destination": "/netmonitor/settings.html" },
    { "source": "/assettracker", "destination": "/assettracker/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co; frame-ancestors 'none';"
        }
      ]
    }
  ],
  "trailingSlash": false
}
